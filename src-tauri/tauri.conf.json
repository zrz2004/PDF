{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalPDF Studio",
  "version": "1.0.0",
  "identifier": "com.localpdf.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalPDF Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "LocalPDF Studio",
    "shortDescription": "Local PDF and file conversion workbench",
    "longDescription": "A local-first Windows desktop file conversion workbench with PDF tools, Office conversion, image conversion, jobs, logs, and engine diagnostics."
  }
}
